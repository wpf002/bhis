# BHIS backend configuration. Copy to .env for local dev, or set these as
# environment variables in your host (Railway/Render/Fly/etc.). Defaults live in
# app/config.py — only DATABASE_URL and SECRET_KEY are truly required in prod.

# ── Required in production ────────────────────────────────────────────────────
# Async SQLAlchemy URL (note the +asyncpg driver).
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/bhis
# Long random string. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
# Public URL of the frontend — used to build verify/reset/report links in emails.
FRONTEND_URL=https://app.bhis.example

# ── Auth / tokens ─────────────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
VERIFY_TOKEN_EXPIRE_HOURS=24
RESET_TOKEN_EXPIRE_HOURS=1

# ── Rate limiting (per client IP, fixed window) ──────────────────────────────
LOGIN_RATE_LIMIT=10
REGISTER_RATE_LIMIT=5
RATE_LIMIT_WINDOW_SECONDS=60

# ── Email ─────────────────────────────────────────────────────────────────────
# console (logs only) | sendgrid
EMAIL_BACKEND=sendgrid
EMAIL_FROM=no-reply@bhis.example
SENDGRID_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
# Leave SENTRY_DSN empty to disable. Install sentry-sdk to enable (see requirements.txt).
SENTRY_DSN=
SLOW_REQUEST_MS=2000

# ── Misc ──────────────────────────────────────────────────────────────────────
# Sub-this-many-seconds completions are flagged as likely bots.
MIN_COMPLETION_SECONDS=120
# Reserved for a future Redis-backed rate limiter (in-memory today).
REDIS_URL=redis://localhost:6379
